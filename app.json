{
  "expo": {
    "name": "SpotBell",
    "slug": "my-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "plugins": [
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/alarm.wav"
          ]
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location."
        }
      ]
    ],
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#01123e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shivr7.SpotBell",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "location"
        ],
        "NSLocationWhenInUseUsageDescription": "SpotBell needs your location to track your journey.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "SpotBell needs background location to wake you up before your stop."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.shivr7.myapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "c4d30b5f-f9a4-46ec-b2ad-c58f9595bb10"
      }
    },
    "owner": "shivr7"
  }
}